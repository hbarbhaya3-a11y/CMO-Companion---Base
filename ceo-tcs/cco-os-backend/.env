# Use sqlite for out of the box testing, switch to postgres if available
DATABASE_URL=sqlite:///./cxo_db.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cxo_db
GOOGLE_CLOUD_PROJECT=gpi-tcs-twinx-iscm-01nl161418
GOOGLE_CLOUD_LOCATION=global
GCP_LOCATION=global
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_BRIEF_MODEL=gemini-3.1-flash-lite
GEMINI_TEMPERATURE=0.4
GEMINI_MAX_TOKENS=20000
ENABLE_GOOGLE_SEARCH=true

# ── Companion LLM provider ────────────────────────────────────────
# Default provider when the UI toggle doesn't specify one: gemini | slm
LLM_PROVIDER=gemini
# SLM = llama-server on the GPU VM (OpenAI-compatible /v1/chat/completions)
SLM_BASE_URL=http://10.0.2.2:11434
SLM_API_KEY=qwen-ups-finetuned
SLM_MODEL=qwen-ups
SLM_TEMPERATURE=0.6
SLM_MAX_TOKENS=16000
JWT_SECRET=cco-ups-secret-change-in-production-2024
JWT_EXPIRE_HOURS=24

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=*