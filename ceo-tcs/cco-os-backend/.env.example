# Backend env — copy to .env for local dev.
# In Docker builds, the .env file is COPYed into the image.
# In Cloud Run, env vars set via --set-env-vars override .env values.

# Database — SQLite for dev, Cloud SQL Postgres for prod
DATABASE_URL=sqlite:///./cxo_db.db
# DATABASE_URL=postgresql://USER:PASS@/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GCP_LOCATION=us-central1

# Gemini model config
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.4
GEMINI_MAX_TOKENS=20000
ENABLE_GOOGLE_SEARCH=true

# Companion LLM provider — which model backs the CXO Companion chat.
# Default when the UI toggle doesn't specify: gemini | slm
LLM_PROVIDER=gemini
# SLM = your fine-tuned model served by llama-server on the GPU VM.
# OpenAI-compatible endpoint: http://<VM_IP>:8080/v1/chat/completions
SLM_BASE_URL=http://YOUR_VM_IP:8080
SLM_API_KEY=your-llama-server-api-key
SLM_MODEL=qwen3-4b-instruct
SLM_TEMPERATURE=0.4
SLM_MAX_TOKENS=2048

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# Server — host/port for uvicorn
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated origins for CORS, or * for all
ALLOWED_ORIGINS=*
