# Frontend env — copy to .env for local dev.

# Local dev
VITE_API_BASE_URL=http://localhost:8000

# Default companion model shown on load: gemini | slm
# (user can flip it live via the toggle in the companion dock header)
VITE_LLM_PROVIDER=gemini

# Server deployment example (set to your backend host:port):
# VITE_API_BASE_URL=http://your-server-ip:8000
